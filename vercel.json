{
  "version": 2,
  "functions": {
    "api/goods.js": { "regions": ["icn1"] },
    "api/prefetch-goods.js": { "regions": ["icn1"] }
  },
  "crons": [
    {
      "path": "/api/sync-naver",
      "schedule": "0 6 * * 1-5"
    },
    {
      "path": "/api/sync-events",
      "schedule": "10 6 * * 1-5"
    },
    {
      "path": "/api/prefetch-goods",
      "schedule": "10 15 * * *"
    },
    {
      "path": "/api/prefetch-goods",
      "schedule": "10 9 * * *"
    }
  ],
  "headers": [
    {
      "source": "/goods/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "s-maxage=86400, stale-while-revalidate=3600" },
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/goods/(.*)", "destination": "/goods/$1" },
    { "source": "/admin", "destination": "/admin.html" },
    { "source": "/market", "destination": "/market.html" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
